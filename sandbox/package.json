{
  "name": "lookout-mcp-tooling",
  "version": "1.0.0",
  "description": "Local tooling for Lookout MCP schema validation, seed generation, and contract tests.",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:verbose": "vitest --reporter verbose",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed/seed.ts",
    "validate": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}